<UserControl x:Class="DataGridExtensionsSample.Views.PagingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:DataGridExtensionsSample.Views"
             xmlns:dgx="urn:tom-englert.de/DataGridExtensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance views:PagingViewModel}">
  <DockPanel>
    <StackPanel Orientation="Horizontal" Margin="5" DockPanel.Dock="Top">
      <Button Content="Load next page" Command="{Binding TakeNextChunkCommand}" Margin="5"/>
      <TextBlock Text="This view demonstrates the usage of paging with server side filtering and sorting" VerticalAlignment="Center"/>
    </StackPanel>
    <DataGrid AutoGenerateColumns="True" 
              IsReadOnly="True" 
              ItemsSource="{Binding Items}" 
              dgx:DataGridFilter.IsAutoFilterEnabled="True"
              dgx:DataGridFilter.StartFilteringKeyGesture="Ctrl+F" />
  </DockPanel>
</UserControl>
